# Copia este archivo como .env y rellena los valores
# Nunca subas el .env real a Git

# MongoDB Atlas: ve a atlas.mongodb.com → tu cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<usuario>:<contraseña>@<cluster>.mongodb.net/APIReact?retryWrites=true&w=majority

# Clave secreta JWT: escribe cualquier texto largo y aleatorio
JWT_SECRET=cambia_esto_por_algo_secreto_y_largo

# Puerto del servidor (por defecto 5000)
PORT=5000
